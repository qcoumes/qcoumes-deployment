DIRNAME="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

export EMUSHPEDIA_FILENAME="emushpedia-$(date +%F)"
export EMUSHPEDIA_DUMP_PATH="${DIRNAME}/downloads/dumps/${EMUSHPEDIA_FILENAME}.zip"
export EMUSHPEDIA_LOG_PATH="${DIRNAME}/downloads/logs/${EMUSHPEDIA_FILENAME}.log"
export EMUSHPEDIA_VENV_PATH="${DIRNAME}/venv"
